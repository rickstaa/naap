{
  "$schema": "./connector-template.schema.json",
  "id": "baseten-serverless",
  "name": "Baseten Model Deployment",
  "description": "Deploy ML models as scalable API endpoints on Baseten with GPU auto-scaling and managed infrastructure.",
  "icon": "🏗️",
  "category": "ai",
  "connector": {
    "slug": "baseten",
    "displayName": "Baseten Model Deployment",
    "description": "Deploy and manage ML model endpoints with GPU auto-scaling on Baseten.",
    "category": "ai",
    "upstreamBaseUrl": "https://api.baseten.co/v1",
    "allowedHosts": ["api.baseten.co"],
    "defaultTimeout": 60000,
    "healthCheckPath": "/",
    "authType": "header",
    "authConfig": {
      "headers": {
        "Authorization": "Api-Key {{secrets.api-key}}"
      }
    },
    "secretRefs": ["api-key"],
    "streamingEnabled": false,
    "responseWrapper": false,
    "tags": ["baseten", "gpu", "model", "deployment", "inference"]
  },
  "endpoints": [
    {
      "name": "list-models",
      "description": "List deployed models",
      "method": "GET",
      "path": "/models",
      "upstreamPath": "/models",
      "rateLimit": 60,
      "timeout": 10000
    },
    {
      "name": "create-model",
      "description": "Deploy a model from a Docker image",
      "method": "POST",
      "path": "/models",
      "upstreamPath": "/models",
      "rateLimit": 10,
      "timeout": 120000
    },
    {
      "name": "get-model",
      "description": "Get model deployment status",
      "method": "GET",
      "path": "/models/:modelId",
      "upstreamPath": "/models/:modelId",
      "rateLimit": 60,
      "timeout": 10000
    },
    {
      "name": "delete-model",
      "description": "Delete a deployed model",
      "method": "DELETE",
      "path": "/models/:modelId",
      "upstreamPath": "/models/:modelId",
      "rateLimit": 10,
      "timeout": 30000
    },
    {
      "name": "update-model",
      "description": "Update model deployment configuration",
      "method": "PATCH",
      "path": "/models/:modelId",
      "upstreamPath": "/models/:modelId",
      "rateLimit": 10,
      "timeout": 30000
    }
  ],
  "envKey": "BASETEN_API_KEY"
}
