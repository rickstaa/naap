{
  "$schema": "./connector-template.schema.json",
  "id": "replicate-serverless",
  "name": "Replicate Deployments",
  "description": "Deploy custom Docker models as scalable API endpoints on Replicate with dedicated GPU hardware and auto-scaling.",
  "icon": "🔁",
  "category": "ai",
  "connector": {
    "slug": "replicate",
    "displayName": "Replicate Deployments",
    "description": "Deploy custom models as scalable endpoints on Replicate GPU infrastructure.",
    "category": "ai",
    "upstreamBaseUrl": "https://api.replicate.com/v1",
    "allowedHosts": ["api.replicate.com"],
    "defaultTimeout": 60000,
    "healthCheckPath": "/",
    "authType": "bearer",
    "authConfig": {},
    "secretRefs": ["api-key"],
    "streamingEnabled": false,
    "responseWrapper": false,
    "tags": ["replicate", "gpu", "deployment", "inference", "model"]
  },
  "endpoints": [
    {
      "name": "list-deployments",
      "description": "List all deployments",
      "method": "GET",
      "path": "/deployments",
      "upstreamPath": "/deployments",
      "rateLimit": 60,
      "timeout": 10000
    },
    {
      "name": "create-deployment",
      "description": "Create a new deployment from a model",
      "method": "POST",
      "path": "/deployments",
      "upstreamPath": "/deployments",
      "rateLimit": 10,
      "timeout": 120000
    },
    {
      "name": "get-deployment",
      "description": "Get deployment status and configuration",
      "method": "GET",
      "path": "/deployments/:owner/:name",
      "upstreamPath": "/deployments/:owner/:name",
      "rateLimit": 60,
      "timeout": 10000
    },
    {
      "name": "update-deployment",
      "description": "Update deployment configuration",
      "method": "PATCH",
      "path": "/deployments/:owner/:name",
      "upstreamPath": "/deployments/:owner/:name",
      "rateLimit": 10,
      "timeout": 30000
    },
    {
      "name": "delete-deployment",
      "description": "Delete a deployment",
      "method": "DELETE",
      "path": "/deployments/:owner/:name",
      "upstreamPath": "/deployments/:owner/:name",
      "rateLimit": 10,
      "timeout": 30000
    }
  ],
  "envKey": "REPLICATE_API_KEY"
}
