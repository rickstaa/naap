{
  "$schema": "./connector-template.schema.json",
  "id": "modal-serverless",
  "name": "Modal Serverless GPU",
  "description": "Deploy serverless GPU workloads on Modal with sub-second cold starts, elastic scaling, and programmable infrastructure.",
  "icon": "🔮",
  "category": "ai",
  "connector": {
    "slug": "modal",
    "displayName": "Modal Serverless GPU",
    "description": "Serverless GPU infrastructure on Modal — elastic scaling, fast cold starts, programmable containers.",
    "category": "ai",
    "upstreamBaseUrl": "https://api.modal.com/api",
    "allowedHosts": ["api.modal.com"],
    "defaultTimeout": 60000,
    "healthCheckPath": "/",
    "authType": "bearer",
    "authConfig": {},
    "secretRefs": ["api-key"],
    "streamingEnabled": false,
    "responseWrapper": false,
    "tags": ["modal", "gpu", "serverless", "deployment", "inference"]
  },
  "endpoints": [
    {
      "name": "list-apps",
      "description": "List deployed Modal apps",
      "method": "GET",
      "path": "/apps",
      "upstreamPath": "/apps",
      "rateLimit": 60,
      "timeout": 10000
    },
    {
      "name": "deploy-app",
      "description": "Deploy a new Modal app with GPU configuration",
      "method": "POST",
      "path": "/apps",
      "upstreamPath": "/apps",
      "rateLimit": 10,
      "timeout": 120000
    },
    {
      "name": "get-app",
      "description": "Get app deployment status and details",
      "method": "GET",
      "path": "/apps/:appId",
      "upstreamPath": "/apps/:appId",
      "rateLimit": 60,
      "timeout": 10000
    },
    {
      "name": "stop-app",
      "description": "Stop a running Modal app",
      "method": "DELETE",
      "path": "/apps/:appId",
      "upstreamPath": "/apps/:appId",
      "rateLimit": 10,
      "timeout": 30000
    },
    {
      "name": "update-app",
      "description": "Update app configuration or redeploy",
      "method": "PUT",
      "path": "/apps/:appId",
      "upstreamPath": "/apps/:appId",
      "rateLimit": 10,
      "timeout": 60000
    }
  ],
  "envKey": "MODAL_API_KEY"
}
