{
  "name": "NAAP Platform",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.devcontainer.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [3000, 3100, 4000, 4020, 5432, 9092],
  "portsAttributes": {
    "3000": { "label": "Web Shell (Next.js)", "onAutoForward": "notify" },
    "3100": { "label": "Plugin Server", "onAutoForward": "silent" },
    "4000": { "label": "Base Service", "onAutoForward": "silent" },
    "4020": { "label": "Pipeline Gateway", "onAutoForward": "silent" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "9092": { "label": "Kafka", "onAutoForward": "silent" }
  },
  "postCreateCommand": "npm install && npm run db:setup",
  "postStartCommand": "npm run dev",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "nrwl.angular-console"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.preferences.importModuleSpecifier": "non-relative"
      }
    }
  }
}
